# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# 실제 매출 데이터/업로드 샘플 (git 제외)
/docs/

# 하네스 워크스페이스 중간 산출물은 보존, 임시 파일만 제외
# (.md 설계문서는 트래킹, 일회성 검증/적재 스크립트와 로그는 제외)
/_workspace/_tmp/
/_workspace/*.mjs
/_workspace/*.ts
/_workspace/*.log
